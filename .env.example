# App environment
NODE_ENV=development
PORT=3000

# Shared runtime
LOG_LEVEL=debug
MAX_STEPS=5
HTTP_PROXY_URL=http://127.0.0.1:7890

# Optional shared defaults
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
ANTHROPIC_VERSION=2023-06-01

# Registered models
LLM_MODELS=my_openai,my_code,my_claude

# Current active model
LLM_ACTIVE_MODEL=my_code

# Supported protocol values:
# - openai-responses
# - openai-completions
# - anthropic-messages

# Custom OpenAI Responses model alias
LLM_MODEL_MY_OPENAI_PROTOCOL=openai-responses
LLM_MODEL_MY_OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL_MY_OPENAI_API_KEY=your_openai_api_key_here
# Optional: if omitted, defaults to model id "my_openai"
LLM_MODEL_MY_OPENAI_MODEL=gpt-4o-mini

# Custom coding model alias (OpenAI Chat Completions compatible)
LLM_MODEL_MY_CODE_PROTOCOL=openai-completions
LLM_MODEL_MY_CODE_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
LLM_MODEL_MY_CODE_API_KEY=your_volcengine_api_key_here
# Optional: if omitted, defaults to model id "my_code"
LLM_MODEL_MY_CODE_MODEL=ark-code-latest

# Custom Anthropic model alias
LLM_MODEL_MY_CLAUDE_PROTOCOL=anthropic-messages
LLM_MODEL_MY_CLAUDE_BASE_URL=https://api.anthropic.com/v1
LLM_MODEL_MY_CLAUDE_API_KEY=your_anthropic_api_key_here
# Optional: if omitted, defaults to model id "my_claude"
LLM_MODEL_MY_CLAUDE_MODEL=claude-sonnet-4-20250514
LLM_MODEL_MY_CLAUDE_ANTHROPIC_VERSION=2023-06-01
LLM_MODEL_MY_CLAUDE_MAX_TOKENS=1024
