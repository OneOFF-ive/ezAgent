# App environment
NODE_ENV=development
PORT=3000

# Shared runtime
LOG_LEVEL=debug
MAX_STEPS=5
HTTP_PROXY_URL=http://127.0.0.1:7890

# LLM provider switch
# Supported values:
# - openai
# - volcengine-coding
# - openai-compatible
LLM_PROVIDER=openai

# Optional overrides for any provider
# If LLM_API_STYLE is omitted, it is chosen automatically from LLM_PROVIDER:
# - openai -> responses
# - volcengine-coding -> chat-completions
# - openai-compatible -> chat-completions
# LLM_API_STYLE=responses
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your_api_key_here
# LLM_MODEL=gpt-4o-mini

# OpenAI preset
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Volcengine Coding Plan preset
VOLCENGINE_API_KEY=your_volcengine_api_key_here
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
VOLCENGINE_MODEL=ark-code-latest
